                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    s.ShipDate AS InventoryDate,
    pr.PackagingType AS ProductCode,
    pr.BatchNumber AS BatchCode,
    s.QuantityShippedKg AS InventoryQuantity
FROM dbo.Shipment s
INNER JOIN dbo.ProcessingRun pr
    ON s.RunID = pr.RunID
WHERE s.ShipDate IS NOT NULL;</property>
