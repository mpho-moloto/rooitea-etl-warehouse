            <component
              refId="Package\Load FactSales\SRC_Sales"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="SRC_Sales"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    oh.OrderDate AS SaleDate,
    ol.ProductType AS ProductCode,
    CAST(oh.CustomerID AS VARCHAR(30)) AS CustomerCode,
    oh.CurrencyCode,
    c.Country AS CountryName,
    UPPER(LTRIM(RTRIM(CAST(c.MarketType AS VARCHAR(30))))) AS MarketTypeCode,
    NULL AS CentreCode,
    NULL AS BatchCode,
    ol.Quantity AS UnitsSold,
    ol.SalesAmount AS SalesValueZAR,
    1 AS ShipmentCount,
    
    -- These pull the exchange rate keys straight from RooiTeaDW based on date ranges
    er.ExchangeRateKey AS LKP_ExchangeRateKey,
    er.ExchangeRateToZAR AS LKP_ExchangeRateToZAR
FROM dbo.OrderHeader oh
INNER JOIN dbo.OrderLine ol 
    ON oh.OrderID = ol.OrderID
INNER JOIN dbo.Customer c 
    ON oh.CustomerID = c.CustomerID
-- This JOIN connects to your DW database and finds the active rate period
LEFT JOIN (    
    SELECT 
        ex.ExchangeRateKey,
        cur.CurrencyCode,
        ex.DateKey AS ValidFrom,
        COALESCE(
            (SELECT MIN(b.DateKey) - 1 
             FROM RooiTeaDW.dbo.DimExchangeRate b  
             WHERE b.CurrencyKey = ex.CurrencyKey AND b.DateKey &gt; ex.DateKey), 
            99991231
        ) AS ValidTo,
        ex.ExchangeRateToZAR
    FROM RooiTeaDW.dbo.DimExchangeRate ex          
    INNER JOIN RooiTeaDW.dbo.DimCurrency cur        
        ON ex.CurrencyKey = cur.CurrencyKey
) er 
    ON oh.CurrencyCode = er.CurrencyCode 
    AND (YEAR(oh.OrderDate) * 10000 + MONTH(oh.OrderDate) * 100 + DAY(oh.OrderDate)) BETWEEN er.ValidFrom AND er.ValidTo
WHERE oh.OrderDate IS NOT NULL;</property>
                <property
                  dataType="System.String"
                  description="The variable that contains the SQL command to be executed."
                  name="SqlCommandVariable"></property>
                <property
                  dataType="System.Int32"
                  description="Specifies the column code page to use when code page information is unavailable from the data source."
                  name="DefaultCodePage">1252</property>
                <property
                  dataType="System.Boolean"
                  description="Forces the use of the DefaultCodePage property value when describing character data."
                  name="AlwaysUseDefaultCodePage">false</property>
                <property
                  dataType="System.Int32"
                  description="Specifies the mode used to access the database."
                  name="AccessMode"
                  typeConverter="AccessMode">2</property>
                <property
                  dataType="System.String"
                  description="The mappings between the parameters in the SQL command and variables."
                  name="ParameterMapping"></property>
              </properties>
