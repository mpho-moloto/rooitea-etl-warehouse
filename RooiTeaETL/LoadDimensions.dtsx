                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT 
    ProductType AS ProductCode,
    ProductType AS ProductName, 
    ProductType AS ProductTypeCode, 
    ProductType AS PackagingType, 
    NULL AS UnitSize, 
    NULL AS StandardUnitPriceZAR, 
    CAST(1 AS BIT) AS ActiveFlag 
FROM dbo.OrderLine 
WHERE ProductType IS NOT NULL 
    AND LEN(TRIM(ProductType)) &gt; 0;</property>
