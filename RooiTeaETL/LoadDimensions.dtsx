                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT
    UPPER(TRIM(MarketType COLLATE DATABASE_DEFAULT)) AS MarketTypeCode,
    MarketType COLLATE DATABASE_DEFAULT AS MarketTypeName
FROM dbo.Customer
WHERE MarketType IS NOT NULL 
    AND LEN(TRIM(MarketType)) &gt; 0

UNION

SELECT DISTINCT
    UPPER(TRIM(MarketType COLLATE DATABASE_DEFAULT)),
    MarketType COLLATE DATABASE_DEFAULT
FROM RooiTea_Distribution.dbo.Shipment
WHERE MarketType IS NOT NULL 
    AND LEN(TRIM(MarketType)) &gt; 0;</property>
