                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT
CASE UPPER(TRIM(DestinationCountry COLLATE DATABASE_DEFAULT))
WHEN 'SOUTH AFRICA'   THEN 'ZA'
WHEN 'UNITED KINGDOM' THEN 'GB'
WHEN 'AUSTRALIA'      THEN 'AU'
WHEN 'NETHERLANDS'    THEN 'NL'
WHEN 'JAPAN'          THEN 'JP'
ELSE NULL
END                                                 AS CountryCode,
DestinationCountry COLLATE DATABASE_DEFAULT         AS CountryName,
UPPER(TRIM(MarketType COLLATE DATABASE_DEFAULT))    AS MarketTypeCode
FROM RooiTea_Distribution.dbo.Shipment
WHERE DestinationCountry IS NOT NULL
AND LEN(TRIM(DestinationCountry)) &gt; 0
AND MarketType IS NOT NULL
UNION
SELECT DISTINCT
CASE UPPER(TRIM(Country COLLATE DATABASE_DEFAULT))
WHEN 'SOUTH AFRICA'   THEN 'ZA'
WHEN 'UNITED KINGDOM' THEN 'GB'
WHEN 'AUSTRALIA'      THEN 'AU'
WHEN 'NETHERLANDS'    THEN 'NL'
WHEN 'JAPAN'          THEN 'JP'
ELSE NULL
END                                                 AS CountryCode,
Country COLLATE DATABASE_DEFAULT                    AS CountryName,
UPPER(TRIM(MarketType COLLATE DATABASE_DEFAULT))    AS MarketTypeCode
FROM RooiTea_Sales.dbo.Customer
WHERE Country IS NOT NULL
AND LEN(TRIM(Country)) &gt; 0
AND MarketType IS NOT NULL;</property>
