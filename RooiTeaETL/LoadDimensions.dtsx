                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT 
    src.ProductType AS ProductTypeCode, 
    src.ProductType AS ProductTypeName,
    dpc.ProductCategoryKey
FROM dbo.OrderLine src
CROSS JOIN RooiTeaDW.dbo.DimProductCategory dpc
WHERE src.ProductType IS NOT NULL 
  AND LEN(TRIM(src.ProductType)) &gt; 0
  AND (
      (src.ProductType = 'Bulk Export' AND dpc.ProductCategoryCode = 'BULK') OR
      (src.ProductType IN ('Loose Leaf', 'Teabags') AND dpc.ProductCategoryCode = 'RETAIL')
  );</property>
