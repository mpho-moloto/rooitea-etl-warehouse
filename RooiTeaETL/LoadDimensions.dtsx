                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT 
    CAST(CustomerID AS VARCHAR(30)) AS CustomerCode, 
    CustomerName,
    NULL AS CustomerCity, 
    NULL AS CustomerStatus,
    CASE UPPER(TRIM(MarketType))
        WHEN 'LOCAL' THEN 'DOM-RETAIL'
        WHEN 'EXPORT' THEN 'EXP-INTL'
        ELSE 'DOM-RETAIL'
    END AS MarketSegmentCode,
    Country AS CountryName,
    UPPER(TRIM(MarketType)) AS MarketTypeCode
FROM dbo.Customer 
WHERE CustomerID IS NOT NULL;</property>
