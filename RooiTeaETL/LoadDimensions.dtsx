          SQLTask:SqlStatementSource="DELETE FROM dbo.DimExchangeRate;&#xA;DELETE FROM dbo.DimFarm;&#xA;DELETE FROM dbo.DimCustomer;&#xA;DELETE FROM dbo.DimCurrency;&#xA;DELETE FROM dbo.DimRegion;&#xA;DELETE FROM dbo.DimDistributionCentre;&#xA;DELETE FROM dbo.DimMarketSegment;&#xA;DELETE FROM dbo.DimProduct;&#xA;DELETE FROM dbo.DimProvince;&#xA;DELETE FROM dbo.DimQualityGrade;&#xA;DELETE FROM dbo.DimProductType;&#xA;DELETE FROM dbo.DimDestinationCountry;&#xA;DELETE FROM dbo.DimProductCategory;&#xA;DELETE FROM dbo.DimQualityClass;&#xA;DELETE FROM dbo.DimCountry;&#xA;DELETE FROM dbo.DimMarketType;&#xA;DELETE FROM dbo.DimDate;&#xA;&#xA;DBCC CHECKIDENT ('dbo.DimFarm', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimCustomer', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimCurrency', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimRegion', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimDistributionCentre', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimMarketSegment', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimProduct', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimProvince', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimQualityGrade', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimProductType', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimDestinationCountry', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimProductCategory', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimQualityClass', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimCountry', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimMarketType', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.DimExchangeRate', RESEED, 0);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
