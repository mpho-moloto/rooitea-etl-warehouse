                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">(DT_STR,50,1252)(#{Package\Load Currency\Sort.Outputs[Sort Output].Columns[CurrencyCode]} == "ZAR" ? "South African Rand" : #{Package\Load Currency\Sort.Outputs[Sort Output].Columns[CurrencyCode]} == "GBP" ? "British Pound" : #{Package\Load Currency\Sort.Outputs[Sort Output].Columns[CurrencyCode]} == "AUD" ? "Australian Dollar" : #{Package\Load Currency\Sort.Outputs[Sort Output].Columns[CurrencyCode]} == "EUR" ? "Euro" : #{Package\Load Currency\Sort.Outputs[Sort Output].Columns[CurrencyCode]} == "JPY" ? "Japanese Yen" : #{Package\Load Currency\Sort.Outputs[Sort Output].Columns[CurrencyCode]})</property>
