                          dataType="System.String"
                          description="Derived Column Friendly Expression"
                          expressionType="Notify"
                          name="FriendlyExpression">(DT_STR,50,1252)(CurrencyCode == "ZAR" ? "South African Rand" : CurrencyCode == "GBP" ? "British Pound" : CurrencyCode == "AUD" ? "Australian Dollar" : CurrencyCode == "EUR" ? "Euro" : CurrencyCode == "JPY" ? "Japanese Yen" : CurrencyCode)</property>
