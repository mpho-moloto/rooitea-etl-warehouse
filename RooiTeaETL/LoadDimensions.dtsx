                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT 
    NULL AS RegionCode, 
    src.Region AS RegionName,
    dp.ProvinceKey
FROM dbo.Farm src
CROSS JOIN RooiTeaDW.dbo.DimProvince dp
WHERE src.Region IS NOT NULL 
  AND LEN(TRIM(src.Region)) &gt; 0
  AND dp.ProvinceName = 'Western Cape';</property>
