    WHEN 'Premium' THEN 'A'
    WHEN 'Standard' THEN 'B'
    ELSE NULL
 END AS QualityClassCode 
FROM dbo.HarvestBatch 
WHERE QualityGrade IS NOT NULL 
    AND LEN(TRIM(QualityGrade)) &gt; 0;</property>
